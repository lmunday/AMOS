<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.43.1" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="RestaurantUI">
    <bpmn:participant id="restaurantUI" name="Restaturant UI" processRef="restaurantUIProces" />
  </bpmn:collaboration>
  <bpmn:process id="restaurantUIProces" name="Restaurant UI Process" isExecutable="true">
    <bpmn:laneSet id="LaneSet_12qkn7d">
      <bpmn:lane id="updateRestaturantUIDisplay" name="Update Display">
        <bpmn:flowNodeRef>turnedOn</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>openRestaurant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>initializeRestiarantUI</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>closeRestaurant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_19yr1pv</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="monitorRestaurantUIInput" name="Monitor Input">
        <bpmn:flowNodeRef>selectATable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>informSelectedTable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0p2iry0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0o2ju6h</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>_updateTableStatus</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="selectATable" name="Select A Table">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="RestaurantScreen" />
        <zeebe:ioMapping>
          <zeebe:output source="=selectedTable" target="tableLocation" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1aga161</bpmn:incoming>
      <bpmn:outgoing>Flow_16m1nqv</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="informSelectedTable" name="Inform Selected Table" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="_selectTable" target="messageName" />
          <zeebe:input source="tableLocation" target="correlationKey" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_16m1nqv</bpmn:incoming>
      <bpmn:outgoing>Flow_0ciwabh</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gateway_0p2iry0">
      <bpmn:incoming>Flow_0ciwabh</bpmn:incoming>
      <bpmn:incoming>Flow_1t8x4xv</bpmn:incoming>
      <bpmn:incoming>Flow_0p3wm7h</bpmn:incoming>
      <bpmn:outgoing>Flow_1aga161</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1cc7pcd" sourceRef="turnedOn" targetRef="initializeRestiarantUI" />
    <bpmn:sequenceFlow id="Flow_0p0cweo" sourceRef="initializeRestiarantUI" targetRef="openRestaurant" />
    <bpmn:sequenceFlow id="Flow_1aga161" sourceRef="Gateway_0p2iry0" targetRef="selectATable" />
    <bpmn:sequenceFlow id="Flow_16m1nqv" sourceRef="selectATable" targetRef="informSelectedTable" />
    <bpmn:sequenceFlow id="Flow_0ciwabh" sourceRef="informSelectedTable" targetRef="Gateway_0p2iry0" />
    <bpmn:sequenceFlow id="Flow_0n6i7nu" sourceRef="closeRestaurant" targetRef="Event_19yr1pv" />
    <bpmn:startEvent id="turnedOn" name="_restaurantTurnedOn">
      <bpmn:outgoing>Flow_1cc7pcd</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:boundaryEvent id="Event_0o2ju6h" name="Open for 8 Hours" attachedToRef="selectATable">
      <bpmn:outgoing>Flow_14nec9f</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0snxe48">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT8H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_1t8x4xv" sourceRef="openRestaurant" targetRef="Gateway_0p2iry0" />
    <bpmn:boundaryEvent id="_updateTableStatus" name="_updateTableStatus" attachedToRef="selectATable">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=tableLocation" target="tableLocation" />
          <zeebe:output source="=tableStatus" target="tableStatus" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0p3wm7h</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_09d09y5" messageRef="Message_3v2o974" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0p3wm7h" sourceRef="_updateTableStatus" targetRef="Gateway_0p2iry0" />
    <bpmn:sendTask id="openRestaurant" name="Open Restaurant" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="_openRestaurant" target="messageName" />
          <zeebe:input source="={&#34;restaurantId&#34;:restaurantId}" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0p0cweo</bpmn:incoming>
      <bpmn:outgoing>Flow_1t8x4xv</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="initializeRestiarantUI" name="Initialize Restiarant UI">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="OpenRestaurant" />
        <zeebe:ioMapping>
          <zeebe:output source="=restaurantId" target="restaurantId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1cc7pcd</bpmn:incoming>
      <bpmn:outgoing>Flow_0p0cweo</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_14nec9f" sourceRef="Event_0o2ju6h" targetRef="closeRestaurant" />
    <bpmn:sendTask id="closeRestaurant" name="Close Restaurant" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="_closingTime" target="messageName" />
          <zeebe:input source="restaurantId" target="correlationKey" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14nec9f</bpmn:incoming>
      <bpmn:outgoing>Flow_0n6i7nu</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_19yr1pv" name="UI Turned Off">
      <bpmn:incoming>Flow_0n6i7nu</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmn:signal id="Signal_1utck8k" name="_openingTime" />
  <bpmn:message id="Message_3v2o974" name="_updateTableStatus">
