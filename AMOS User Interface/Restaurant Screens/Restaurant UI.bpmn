    <bpmn:userTask id="selectATable" name="Select A Table">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="RestaurantScreen" />
        <zeebe:ioMapping>
          <zeebe:output source="=tableLocation" target="selectedTable" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1aga161</bpmn:incoming>
      <bpmn:outgoing>Flow_16m1nqv</bpmn:outgoing>
