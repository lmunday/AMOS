  <bpmn:process id="paymentProcess" name="Payment Process" isExecutable="true">
    <bpmn:startEvent id="createPayment" name="Create Payment">
      <bpmn:outgoing>Flow_0d5gkyn</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0dh0odd" messageRef="Message_13p2rcj" />
    </bpmn:startEvent>
    <bpmn:scriptTask id="initializePayment" name="Initialize Payment">
      <bpmn:extensionElements>
        <zeebe:script expression="=Payment.customerId=event.customerId,&#10;Payment.amount=event.amount,&#10;Payment.paymentType=event.PaymentType,&#10;Payment.paymentInformation=event.paymentInformation," resultVariable="customerId" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0d5gkyn</bpmn:incoming>
      <bpmn:outgoing>Flow_085ogj6</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sendTask id="sendPayment" name="Send Payment">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="sendPayment(paymentId)" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_085ogj6</bpmn:incoming>
      <bpmn:outgoing>Flow_0q38yh7</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gateway_1sd8mx4" default="Flow_07h01wz">
      <bpmn:incoming>Flow_0gfleph</bpmn:incoming>
      <bpmn:outgoing>Flow_1bqspgq</bpmn:outgoing>
      <bpmn:outgoing>Flow_07h01wz</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="classNameDeleted" name="Class Name Deleted">
      <bpmn:incoming>Flow_1s1hbcg</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:scriptTask id="deletePayment" name="Delete Payment">
      <bpmn:extensionElements>
        <zeebe:script expression="=customerId=null" resultVariable="customerId" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0wviv1w</bpmn:incoming>
      <bpmn:outgoing>Flow_1s1hbcg</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gateway_14004gl">
      <bpmn:incoming>Flow_1m9l9ls</bpmn:incoming>
      <bpmn:incoming>Flow_1vl76m5</bpmn:incoming>
      <bpmn:outgoing>Flow_0wviv1w</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="acceptPayment" name="Accept Payment">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="acceptedPayment" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1bqspgq</bpmn:incoming>
    </bpmn:sendTask>
    <bpmn:sendTask id="rejectPayment" name="Reject Payment">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="rejectedPayment" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_07h01wz</bpmn:incoming>
    </bpmn:sendTask>
    <bpmn:receiveTask id="receivePaymentResult" name="Receive Payment Result">
      <bpmn:incoming>Flow_0q38yh7</bpmn:incoming>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="Event_10dz2ta" name="deletePayment" attachedToRef="rejectPayment">
      <bpmn:outgoing>Flow_1m9l9ls</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1s6zvlq" messageRef="Message_1nd0us9" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_0ahoyt4" name="deletePayment" attachedToRef="acceptPayment">
      <bpmn:outgoing>Flow_1vl76m5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0ln4dvg" messageRef="Message_1nd0us9" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_0l393u2" name="paymentResult" attachedToRef="receivePaymentResult">
      <bpmn:outgoing>Flow_0gfleph</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0k908mh" messageRef="Message_0cli78d" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0d5gkyn" sourceRef="createPayment" targetRef="initializePayment" />
    <bpmn:sequenceFlow id="Flow_085ogj6" sourceRef="initializePayment" targetRef="sendPayment" />
    <bpmn:sequenceFlow id="Flow_0q38yh7" sourceRef="sendPayment" targetRef="receivePaymentResult" />
    <bpmn:sequenceFlow id="Flow_0gfleph" sourceRef="Event_0l393u2" targetRef="Gateway_1sd8mx4" />
    <bpmn:sequenceFlow id="Flow_1bqspgq" sourceRef="Gateway_1sd8mx4" targetRef="acceptPayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=paymentAccepted</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_07h01wz" sourceRef="Gateway_1sd8mx4" targetRef="rejectPayment" />
    <bpmn:sequenceFlow id="Flow_1s1hbcg" sourceRef="deletePayment" targetRef="classNameDeleted" />
    <bpmn:sequenceFlow id="Flow_0wviv1w" sourceRef="Gateway_14004gl" targetRef="deletePayment" />
    <bpmn:sequenceFlow id="Flow_1m9l9ls" sourceRef="Event_10dz2ta" targetRef="Gateway_14004gl" />
    <bpmn:sequenceFlow id="Flow_1vl76m5" sourceRef="Event_0ahoyt4" targetRef="Gateway_14004gl" />
  </bpmn:process>
