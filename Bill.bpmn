    <bpmn:sequenceFlow id="Flow_18ezgxs" sourceRef="initializeBill" targetRef="Gateway_0e8jck3" />
    <bpmn:sequenceFlow id="outstandingBalance" name="outstandingBalance" sourceRef="Gateway_0u7xhax" targetRef="Gateway_0e8jck3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=bill.cost&gt;0</bpmn:conditionExpression>
