      <bpmn:incoming>Flow_0jl3tja</bpmn:incoming>
      <bpmn:outgoing>Flow_0qk4z48</bpmn:outgoing>
      <bpmn:outgoing>Flow_1lqk39o</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="_acceptedPayment" name="_acceptedPayment">
      <bpmn:incoming>Flow_0qk4z48</bpmn:incoming>
      <bpmn:outgoing>Flow_0hjvwfq</bpmn:outgoing>
