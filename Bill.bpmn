<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1y2kcjw" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.43.1" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Bill">
    <bpmn:participant id="bill" name="Bill" processRef="billProcess">
      <bpmn:documentation>{
"bill" : {
		"tableId": "",
		"customerId": "",
		"amount": 0.0
		}
}</bpmn:documentation>
    </bpmn:participant>
  </bpmn:collaboration>
  <bpmn:process id="billProcess" name="Bill Process" isExecutable="true">
    <bpmn:exclusiveGateway id="Gateway_0e8jck3">
      <bpmn:incoming>Flow_18ezgxs</bpmn:incoming>
      <bpmn:incoming>outstandingBalance</bpmn:incoming>
      <bpmn:incoming>Flow_1umg37r</bpmn:incoming>
      <bpmn:outgoing>Flow_0jxu1uj</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="displayBill" name="Display Bill" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="_displayBill" target="messageName" />
          <zeebe:input source="tableId" target="correlationKey" />
          <zeebe:input source="bill.cost, bill.tax" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0jxu1uj</bpmn:incoming>
      <bpmn:outgoing>Flow_1b4det3</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Activity_0w8vuf6" name="Create Payment" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="_createPayment" target="messageName" />
          <zeebe:input source="customerId" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1rpknag</bpmn:incoming>
      <bpmn:outgoing>Flow_0jl3tja</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:scriptTask id="initializeBill" name="Initialize Bill">
      <bpmn:extensionElements>
        <zeebe:script expression="=// Sum of all ordered food costs.&#10;sum([10, 20, 30, 40, 50])" resultVariable="bill.cost" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0d5gkyn</bpmn:incoming>
      <bpmn:outgoing>Flow_18ezgxs</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:startEvent id="_createBill" name="_createBill">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=customerId" target="bill.customerId" />
          <zeebe:output source="=tableLocation" target="bill.tableLocation" />
          <zeebe:output source="=0" target="bill.amount" />
          <zeebe:output source="=orderedFoodList" target="bill.orderdFoodList" />
          <zeebe:output source="=0" target="bill.tax" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0d5gkyn</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0dh0odd" messageRef="Message_1lp03qb" />
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="_enteredPayment" name="_enteredPayment">
      <bpmn:incoming>Flow_1b4det3</bpmn:incoming>
