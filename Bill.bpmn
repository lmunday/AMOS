      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0jxu1uj</bpmn:incoming>
    </bpmn:sendTask>
    <bpmn:endEvent id="classNameDeleted" name="deleted">
      <bpmn:incoming>Flow_1s1hbcg</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:scriptTask id="deleteBill" name="Delete Bill">
      <bpmn:extensionElements>
        <zeebe:script expression="=null" resultVariable="bill.customerId" />
      </bpmn:extensionElements>
      <bpmn:incoming>billPaid</bpmn:incoming>
      <bpmn:outgoing>Flow_1s1hbcg</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gateway_0u7xhax">
      <bpmn:incoming>Flow_19dqlpu</bpmn:incoming>
      <bpmn:outgoing>outstandingBalance</bpmn:outgoing>
      <bpmn:outgoing>billPaid</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:scriptTask id="Activity_01dihyz" name="Determine If Bill Paid">
      <bpmn:extensionElements>
        <zeebe:script expression="=cost-amount" resultVariable="cost" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1xr9gvf</bpmn:incoming>
      <bpmn:outgoing>Flow_19dqlpu</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="createPayment" name="Delete Payment">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="createPayment" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0jl3tja</bpmn:incoming>
    </bpmn:scriptTask>
    <bpmn:sendTask id="Activity_0w8vuf6" name="Create Payment">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="createPayment" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1rpknag</bpmn:incoming>
      <bpmn:outgoing>Flow_0jl3tja</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:scriptTask id="initializeBill" name="Initialize Bill">
      <bpmn:extensionElements>
        <zeebe:script expression="=customerId=event.customerId,&#10;cost = 0,&#10;for each orderedFood in Order&#10;  cost=cost+(ordereFo0od.cost+tax),&#10;end for," resultVariable="customerId" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0d5gkyn</bpmn:incoming>
      <bpmn:outgoing>Flow_18ezgxs</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:boundaryEvent id="Event_1mwv64o" name="enteredPayment" attachedToRef="displayBill">
      <bpmn:outgoing>Flow_1rpknag</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0x248p2" messageRef="Message_3ufdjdd" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_0tx2nw8" name="acceptedPayment" attachedToRef="createPayment">
      <bpmn:outgoing>Flow_1xr9gvf</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1gy587h" messageRef="Message_14ushi8" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_0rsp3pc" name="rejectedPayment" attachedToRef="createPayment">
      <bpmn:outgoing>Flow_1umg37r</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_18y75uc" messageRef="Message_2mrvnfd" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0d5gkyn" sourceRef="createBill" targetRef="initializeBill" />
    <bpmn:sequenceFlow id="Flow_18ezgxs" sourceRef="initializeBill" targetRef="Gateway_0e8jck3" />
    <bpmn:sequenceFlow id="outstandingBalance" name="outstandingBalance" sourceRef="Gateway_0u7xhax" targetRef="Gateway_0e8jck3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=cost&gt;0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1umg37r" sourceRef="Event_0rsp3pc" targetRef="Gateway_0e8jck3" />
    <bpmn:sequenceFlow id="Flow_0jxu1uj" sourceRef="Gateway_0e8jck3" targetRef="displayBill" />
    <bpmn:sequenceFlow id="Flow_1s1hbcg" sourceRef="deleteBill" targetRef="classNameDeleted" />
    <bpmn:sequenceFlow id="billPaid" name="billPaid" sourceRef="Gateway_0u7xhax" targetRef="deleteBill">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=cost&lt;=0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_19dqlpu" sourceRef="Activity_01dihyz" targetRef="Gateway_0u7xhax" />
    <bpmn:sequenceFlow id="Flow_1xr9gvf" sourceRef="Event_0tx2nw8" targetRef="Activity_01dihyz" />
    <bpmn:sequenceFlow id="Flow_0jl3tja" sourceRef="Activity_0w8vuf6" targetRef="createPayment" />
    <bpmn:sequenceFlow id="Flow_1rpknag" sourceRef="Event_1mwv64o" targetRef="Activity_0w8vuf6" />
  </bpmn:process>
