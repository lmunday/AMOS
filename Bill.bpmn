    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_0e8jck3">
      <bpmn:incoming>Flow_18ezgxs</bpmn:incoming>
      <bpmn:incoming>outstandingBalance</bpmn:incoming>
      <bpmn:incoming>Flow_1umg37r</bpmn:incoming>
      <bpmn:outgoing>Flow_0jxu1uj</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="displayBill" name="Display Bill">
