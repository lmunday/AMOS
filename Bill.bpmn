    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="_rejectedPayment" name="_rejectedPayment">
      <bpmn:incoming>Flow_1lqk39o</bpmn:incoming>
      <bpmn:outgoing>Flow_0sr2xec</bpmn:outgoing>
